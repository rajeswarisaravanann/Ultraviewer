{
  "name": "ultraviewer-client",
  "version": "1.0.0",
  "main": "main.js",
  "description": "RemoteLink remote desktop client for Windows.",
  "author": "RemoteLink",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis portable",
    "rebuild": "node ./scripts/rebuild-native.js",
    "postinstall": "node ./scripts/rebuild-native.js"
  },
  "dependencies": {
    "socket.io-client": "4.6.1"
  },
  "optionalDependencies": {
    "@jitsi/robotjs": "^0.6.22"
  },
  "devDependencies": {
    "@electron/rebuild": "3.3.0",
    "electron-builder": "^24.6.0",
    "electron": "28.1.0"
  },
  "build": {
    "appId": "com.remotelink.app",
    "productName": "RemoteLink",
    "artifactName": "${productName}_${version}_${arch}-${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RemoteLink"
    }
  }
}
