{
  "name": "ultraviewer-viewer",
  "version": "1.0.0",
  "description": "RemoteLink Viewer",
  "author": "Rajeswari",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "socket.io-client": "4.6.1"
  },
  "devDependencies": {
    "electron": "28.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.remotelink.viewer",
    "productName": "RemoteLink Viewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}